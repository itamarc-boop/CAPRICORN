# Capricorn webapp environment — copy to .env.local and fill in real values.
# See README.md for how to obtain each value.

# ────────────────────────────────────────────────────────────────────
# Supabase
# ────────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Server-side only — NEVER expose to the browser. Used by API routes + Python sync.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────────────
# Google OAuth (for Capricorn client's Gmail mailbox — gmail.send scope)
# ────────────────────────────────────────────────────────────────────
# Created in Google Cloud Console → APIs & Services → Credentials.
# OAuth client type: Web application.
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
# Must match the "Authorized redirect URI" set in Google Cloud for this OAuth client.
# For local dev: http://localhost:3000/api/integrations/google/callback
# For prod:     https://your-app.vercel.app/api/integrations/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ────────────────────────────────────────────────────────────────────
# App config
# ────────────────────────────────────────────────────────────────────
# Public URL of this deployment (used for absolute links in emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────────
# AI drafting + send queue (Phase 2.5)
# ────────────────────────────────────────────────────────────────────
# Anthropic API key — powers "Generate drafts" (claude-sonnet-4-6).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Shared secret the pg_cron scheduler sends to /api/send-queue/tick.
# Generate with: openssl rand -hex 24. Must match the value in
# supabase/pg_cron_send_queue.sql when you wire the scheduler.
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────────────
# Discovery (the in-app "Run" button -> GitHub Actions worker)
# ────────────────────────────────────────────────────────────────────
# The webapp fires a GitHub repository_dispatch to start a pipeline run.
# Fine-grained PAT with "Actions: read and write" on the repo below.
GITHUB_DISPATCH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=capricorn
